    },
    "workspaceHttpDocDialogVisible": false,
    "workspaceHttpDocOp": "add",
    "workspaceHttpDocFormType": "2",
    "workspaceHttpDocForm": {
      "collect_doc_id": "",
      "doc_group_id": "",
      "type": "2",
      "title": "",
      "sub_title": "",
      "parent_dir": "",
