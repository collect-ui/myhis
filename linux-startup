#!/usr/bin/env bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
cd "$SCRIPT_DIR"

export http_proxy=http://10.96.32.180:4780
export https_proxy=http://10.96.32.180:4780

PID_FILE="run-dev.pid"
LOG_FILE="run-dev.log"
CONFIG_FILE="conf/application.properties"
BIN_FILE="./run-dev-main"

if ! command -v go >/dev/null 2>&1; then
  echo "Error: go command not found"
  exit 1
fi

PORT="$(grep -E '^server_port=' "$CONFIG_FILE" 2>/dev/null | head -n 1 | cut -d'=' -f2 || true)"
if [ -z "${PORT:-}" ]; then
  echo "Error: server_port not found in $CONFIG_FILE"
  exit 1
fi

get_port_pids() {
  lsof -t -iTCP:"$PORT" -sTCP:LISTEN 2>/dev/null | sort -u || true
}

health_check() {
  if ! command -v curl >/dev/null 2>&1; then
    return 0
  fi
  local code
  code="$(curl --noproxy '*' -sS -m 3 -o /dev/null -w '%{http_code}' "http://127.0.0.1:${PORT}/" || true)"
  case "$code" in
  200 | 301 | 302 | 401 | 403 | 404)
    return 0
    ;;
  *)
    return 1
    ;;
  esac
}

PORT_PIDS="$(get_port_pids)"
if [ -n "${PORT_PIDS:-}" ]; then
  RUN_PID="$(echo "$PORT_PIDS" | head -n 1)"
  EXE_NAME="$(basename "$(readlink "/proc/${RUN_PID}/exe" 2>/dev/null || echo "")")"
  if [ "$EXE_NAME" = "run-dev-main" ] && health_check; then
    echo "$RUN_PID" >"$PID_FILE"
    echo "[linux-startup] already running on :$PORT pid=$RUN_PID"
    exit 0
  fi
  echo "Error: port :$PORT already in use by pid=$RUN_PID exe=${EXE_NAME:-unknown}"
  echo "Hint: run ./linux-shutdown first, then retry."
  exit 1
fi

if [ -f "$PID_FILE" ]; then
  OLD_PID="$(cat "$PID_FILE" 2>/dev/null || true)"
  if [ -n "${OLD_PID:-}" ] && kill -0 "$OLD_PID" 2>/dev/null; then
    CHILD_PIDS="$(pgrep -P "$OLD_PID" || true)"
    if [ -n "${CHILD_PIDS:-}" ]; then
      kill $CHILD_PIDS 2>/dev/null || true
    fi
    kill "$OLD_PID" 2>/dev/null || true
    sleep 0.5
  fi
  rm -f "$PID_FILE"
fi

echo "[linux-startup] build binary"
go build -o "$BIN_FILE" main.go

echo "[linux-startup] start service"
if command -v setsid >/dev/null 2>&1; then
  setsid "$BIN_FILE" >"$LOG_FILE" 2>&1 < /dev/null &
else
  nohup "$BIN_FILE" >"$LOG_FILE" 2>&1 &
fi
NEW_PID=$!
echo "$NEW_PID" >"$PID_FILE"

ok="0"
for _ in $(seq 1 25); do
  sleep 0.4
  PORT_PIDS="$(get_port_pids)"
  if [ -z "${PORT_PIDS:-}" ]; then
    continue
  fi
  if health_check; then
    ok="1"
    break
  fi
done

if [ "$ok" != "1" ]; then
  echo "Error: start failed, service unhealthy on :$PORT"
  echo "--- recent log ---"
  tail -n 60 "$LOG_FILE" || true
  exit 1
fi

LISTEN_PID="$(echo "$PORT_PIDS" | head -n 1)"
echo "$LISTEN_PID" >"$PID_FILE"

echo "[linux-startup] started, listen pid=$LISTEN_PID"
echo "[linux-startup] log: $SCRIPT_DIR/$LOG_FILE"
echo "[linux-startup] pid file: $SCRIPT_DIR/$PID_FILE"
