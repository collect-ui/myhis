{
  "name": "将字段列表转excel",
  "sheets": [
    {
      "sheet_index": 0,
      "title_height": 48,
      "desc": "16*行数",
      "title_style": {
        "font": {
          "family": "宋体",
          "size": 12,
          "color": "#ffffff"
        },
        "fill": {
          "type": "pattern",
          "color": [
            "#3366FF"
          ],
          "pattern": 1
        },
        "alignment": {
          "vertical": "center",
          "WrapText": true
        }
      },
      "name_style": {
        "font": {
          "family": "Arial",
          "size": 10,
          "color": "#ffffff"
        },
        "fill": {
          "type": "pattern",
          "color": [
            "#0066CC"
          ],
          "pattern": 1
        },
        "alignment": {
          "vertical": "center"
        }
      },
      "content_style": {
        "NumFmt": 49
      },
      "title": "配置列表\r\n",
      "data": "[field_list]",
      "fields": [

        {
          "field": "[key]",
          "enable": false,
          "name": "key",
          "width": 30
        },
        {
          "field": "[name]",
          "enable": false,
          "name": "名称",
          "width": 30
        },

        {
          "field": "[business_group]",
          "name": "业务分类",
          "width": 90
        },
        {
          "field": "[type]",
          "name": "数据类型",
          "width": 40
        },
        {
          "field": "[tag]",
          "name": "显示类型",
          "width": 60
        },
        {
          "field": "[attr]",
          "name": "显示属性",
          "width": 60
        },
        {
          "field": "[data_attr]",
          "name": "数据属性",
          "width": 60
        },
        {
          "field": "[reg]",
          "name": "正则取值",
          "width": 60
        },
        {
          "field": "[order_index]",
          "name": "排序号",
          "width": 60
        },
        {
          "field": "[parent_key]",
          "name": "所属上级",
          "width": 40
        },
        {
          "field": "[link]",
          "name": "生成关联",
          "width": 40
        },
        {
          "field": "[data_from]",
          "name": "取值来源",
          "width": 40
        },
        {
          "field": "[schema_page_code]",
          "name": "页面编码",
          "width": 40
        }
      ]
    }
  ]
}