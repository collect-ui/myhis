{
  "url": "{{.codex_token_url}}",
  "method": "post",
  "header": {
    "Content-Type": "application/x-www-form-urlencoded"
  },
  "result_json": true,
  "data": {
    "grant_type": "authorization_code",
    "code": "[authorization_code]",
    "code_verifier": "[code_verifier]",
    "client_id": "[codex_client_id]",
    "redirect_uri": "[redirect_uri]"
  }
}
