{
  "connect": {
    "server_ip": "[ip]",
    "user": "[username]",
    "password": "[password]",
    "port": "[port]"
  },
  "services": [
    {
      "node_key": "start",
      "node_type": "start",
      "name": "开始",
      "node_next": "info"
    },
    {
      "node_key": "info",
      "node_type": "node",
      "name": "批量读取文本文件",
      "key": "sftp",
      "fields": [
        {
          "name": "批量读取",
          "type": "read_text_batch",
          "save_field": "file_info",
          "field": "{{.paths}}"
        }
      ],
      "node_next": "end",
      "node_fail": "end",
      "save_field": "result"
    },
    {
      "node_key": "end",
      "node_type": "end",
      "name": "结束"
    }
  ]
}
