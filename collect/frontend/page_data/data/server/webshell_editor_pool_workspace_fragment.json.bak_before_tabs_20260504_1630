                                                  "workspaceHttpConsoleUpdatedAt": "${new Date().toISOString()}",
                                                  "workspaceHttpConsoleForm": "${(()=>{const form=workspaceHttpConsoleForm||{};const method=String(form.request_method||'post').toLowerCase();const url=String(form.request_url||'/template_data/data');let headers={};let body={};try{const rawHeaders=String(form.request_headers||'{}').trim();headers=rawHeaders?JSON.parse(rawHeaders):{};}catch(err){headers={};}try{const rawBody=String(form.request_body||'{}').trim();body=rawBody?JSON.parse(rawBody):{};}catch(err){body={};}return {request_method:method||'post',request_url:url||'/template_data/data',request_headers:JSON.stringify(headers&&typeof headers==='object'&&!Array.isArray(headers)?headers:{},null,2),request_body:JSON.stringify(body&&typeof body==='object'&&!Array.isArray(body)?body:{},null,2)};})()}",
                                                  "workspaceHttpDocCacheMap": "${(()=>{const id=String(workspaceHttpWorkbenchDocActiveKey||workspaceHttpConsoleDocId||'');if(!id){return workspaceHttpDocCacheMap||{};}const next=Object.assign({},workspaceHttpDocCacheMap||{});next[id]={selectedDoc:workspaceHttpSelectedDoc||{},consoleForm:workspaceHttpConsoleForm||{request_method:'post',request_url:'/template_data/data',request_headers:'{}',request_body:'{}'},response:String((data&&data.response_text)||'')};return next;})()}"
