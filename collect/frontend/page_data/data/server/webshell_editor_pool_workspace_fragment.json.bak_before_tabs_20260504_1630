              "workspaceLastY": 0,
              "workspaceToken": "",
              "workspaceActivePath": "",
              "workspaceActiveName": "",
              "workspaceHasOpenToken": "",
              "workspaceHttpDocRefreshVersion": "",
              "workspaceHttpConsoleForm": {
                "request_method": "post",
                "request_url": "/template_data/data",
                "request_headers": "{}",
                "request_body": "{}"
              },
              "workspaceHttpWorkbenchActiveTab": "detail",
              "workspaceHttpSelectedDoc": {},
              "workspaceHttpConsoleDocId": "",
              "workspaceHttpConsoleResponse": "",
              "workspaceHttpConsoleStatus": "",
              "workspaceHttpConsoleUpdatedAt": "",
              "workspaceHttpWorkbenchTabs": [],
              "workspaceHttpWorkbenchDocActiveKey": "",
              "workspaceHttpDocCacheMap": {},
              "workspaceHttpDemoOpenKey": "0"
            },
            "initAction": [
              {
                "tag": "update-store",
                "value": {
                  "project_code": "${row && row.project_code ? row.project_code : ''}"
                }
              },
              {
                "tag": "localstore",
                "method": "read",
                "key": "${'workspace-http-recent-'+project_code}",
                "defaultValue": {
                  "list": []
                },
                "storeField": "workspaceHttpRecentCache"
              },
              {
                "tag": "update-store",
                "value": {
                  "workspaceHttpRecentList": "${Array.isArray(workspaceHttpRecentCache&&workspaceHttpRecentCache.list)?workspaceHttpRecentCache.list:[]}"
                }
              },
              {
                "tag": "ajax",
                "enable": "${!!project_code}",
                "group": "reload-workspace-file-tree",
                "api": "post:/template_data/data?service=webshell.workspace_file_query",
                "data": {
                  "project_code": "${project_code}",
                  "root_only": "${(()=>{const fn='workspace-tree-filter-form';const v=(getFormValue(fn,'keyword')||workspaceFileTreeKeyword||'').trim();return !v || v.length<2;})()}",
                  "keyword": "${(()=>{const fn='workspace-tree-filter-form';const v=(getFormValue(fn,'keyword')||workspaceFileTreeKeyword||'').trim();return v.length>=2?v:'';})()}",
                  "pagination": false
                },
                "adapt": {
                  "workspaceFileTreeKeyword": "${(()=>{const fn='workspace-tree-filter-form';const v=(getFormValue(fn,'keyword')||workspaceFileTreeKeyword||'').trim();return v.length>=2?v:'';})()}",
                  "workspaceFileTreeCount": "${Number(count||0.0)}",
                  "workspaceTree": "${(()=>{const src=Array.isArray(data)?data:[];const seen={};const list=src.filter(item=>{const k=String((item&&item.path)||'');if(!k){return false;}if(seen[k]){return false;}seen[k]=true;return true;});const fn='workspace-tree-filter-form';const keyword=((getFormValue(fn,'keyword')||workspaceFileTreeKeyword||'')+'').trim();const isDir=(item)=>item&&(item.is_dir==='1'||item.is_dir===1||item.is_dir===true);const normalizeRoot=(item)=>Object.assign({}, item, { children: undefined, isLeaf: !isDir(item), key: item.file_id||item.path||item.name, title: item.name, __lazy_loaded: false });if(!keyword){return list.map(normalizeRoot);}const roots=[];const nodeMap={};const getOrCreate=(keyPath, title, realPath, dir)=>{if(!nodeMap[keyPath]){nodeMap[keyPath]={key:keyPath,title,path:realPath,is_dir:dir?1:0,children:[],__lazy_loaded:true,isLeaf:!dir};}return nodeMap[keyPath];};const fileList=list.filter(item=>!isDir(item));for(const item of fileList){const fullPath=(item&&item.path)?String(item.path):'';if(!fullPath){continue;}const displayPath=(item&&item.path_display)?String(item.path_display):fullPath;const parts=displayPath.split('/').filter(Boolean);if(parts.length===0){continue;}let parentList=roots;let curDisplay='';for(let i=0;i<parts.length;i++){const seg=parts[i];curDisplay+='/'+seg;const last=i===parts.length-1;const node=getOrCreate(curDisplay, seg, last?fullPath:curDisplay, last?isDir(item):true);if(parentList.indexOf(node)<0){parentList.push(node);}if(last){Object.assign(node, item, { key: item.file_id||curDisplay, title: item.name||seg, path: fullPath, path_display: displayPath, __lazy_loaded:true, children: isDir(item)?(Array.isArray(node.children)?node.children:[]):undefined, isLeaf: !isDir(item) });}if(!Array.isArray(node.children)){node.children=[];}parentList=node.children;}}const prune=(nodes)=>{if(!Array.isArray(nodes)){return [];}return nodes.filter(n=>{if(Array.isArray(n.children)&&n.children.length>0){n.children=prune(n.children);}const dir=(n.is_dir==='1'||n.is_dir===1||n.is_dir===true);return !dir || (Array.isArray(n.children)&&n.children.length>0);});};const sortTree=(nodes)=>{if(!Array.isArray(nodes)){return [];}nodes.sort((a,b)=>{const aDir=(a.is_dir==='1'||a.is_dir===1||a.is_dir===true);const bDir=(b.is_dir==='1'||b.is_dir===1||b.is_dir===true);if(aDir!==bDir){return aDir?-1:1;}return String(a.title||a.name||'').localeCompare(String(b.title||b.name||''));});nodes.forEach(n=>{if(Array.isArray(n.children)&&n.children.length>0){sortTree(n.children);}});return nodes;};return sortTree(prune(roots));})()}",
                  "workspaceFileParentTree": "${Array.isArray(data)?[...data]:[]}",
                  "workspaceTreeSelected": {}
                }
              },
              {
                "tag": "update-store",
                "value": {
                  "workspaceOpenFilesCache": "${workspaceOpenFilesCache||{files:[]}}"
                }
              },
              {
                "tag": "ajax",
                "enable": "${!!project_code}",
                "group": "reload-workspace-recent-files",
                "api": "post:/template_data/data?service=webshell.workspace_file_recent_query",
                "data": {
                  "project_code": "${project_code}"
                },
                "adapt": {
                  "workspaceRecentFileList": "${(()=>{const src=Array.isArray(data)?data:[];const isDir=(n)=>n&&(n.is_dir==='1'||n.is_dir===1||n.is_dir===true);const fmt=(n)=>{const l1=n.title||n.name||'未命名';const l2=n.sub_title||n.cn_title||n.name_zh||n.title_zh||'';return (!isDir(n)&&l2)?(l1+'('+l2+')'):l1;};const walk=(arr)=>{if(!Array.isArray(arr)){return [];}return arr.map(n=>{const children=Array.isArray(n&&n.children)?walk(n.children):undefined;const out=Object.assign({},n,{title:fmt(n),display_title:fmt(n)});if(children){out.children=children;}return out;});};return walk(src);})()}"
                }
              },
              {
                "tag": "ajax",
                "enable": "${!!project_code}",
                "group": "reload-workspace-http-tree",
                "api": "post:/template_data/data?service=config.doc_group_http_service_tree_query",
                "data": {
                  "to_tree": true
                },
                "adapt": {
                  "workspaceHttpTree": "${(()=>{const src=Array.isArray(data)?data:[];const isDir=(n)=>n&&(n.is_dir==='1'||n.is_dir===1||n.is_dir===true);const fmt=(n)=>{const l1=n.title||n.name||'未命名';const l2=n.sub_title||n.cn_title||n.name_zh||n.title_zh||'';return (!isDir(n)&&l2)?(l1+'('+l2+')'):l1;};const walk=(arr)=>{if(!Array.isArray(arr)){return [];}return arr.map(n=>{const children=Array.isArray(n&&n.children)?walk(n.children):undefined;const dir=isDir(n);const rawId=String(n.id||'');const bizId=String(dir?(n.doc_group_id||(rawId.startsWith('g_')?rawId.replace(/^g_/,''):rawId)||''):(n.collect_doc_id||(rawId.startsWith('d_')?rawId.replace(/^d_/,''):rawId)||''));const key=String(n.key||rawId||(dir?('g_'+bizId):('d_'+bizId)));const out=Object.assign({},n,{key,id:bizId,type:dir?'dir':'http',title:fmt(n),display_title:fmt(n)});if(children){out.children=children;}return out;});};return walk(src);})()}",
                  "workspaceHttpTreeSelected": {}
                }
              }
            ],
