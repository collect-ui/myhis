                },
                "backend": {
                  "tree": [],
                  "fileMap": {}
                }
              },
              "workspaceTree": [],
              "workspaceFileMap": {},
              "workspaceTreeSelected": {},
              "workspacePanelList": [],
              "workspaceRecentFileList": [],
              "workspaceLastGroupId": "",
              "workspaceLastShellId": "",
