                                  {
                                    "tag": "css",
                                    "css": ".workspace-http-doc{height:100%;background:linear-gradient(180deg,#fbfefc 0%,#ffffff 100%);overflow:auto;padding:8px;}.workspace-http-hero{border:1px solid rgba(16,24,40,0.08);border-radius:12px;padding:10px 12px;margin-bottom:8px;background:linear-gradient(180deg,rgba(24,226,153,0.08),rgba(24,226,153,0) 56%),#ffffff;box-shadow:0 1px 2px rgba(16,24,40,0.03);}.workspace-http-hero-top{display:flex;align-items:flex-start;justify-content:space-between;gap:8px;flex-wrap:nowrap;}.workspace-http-hero-main{min-width:0;flex:1 1 auto;}.workspace-http-headline{display:flex;align-items:center;gap:8px;min-width:0;}.workspace-http-method{display:inline-flex;align-items:center;justify-content:center;height:20px;padding:0 7px;border-radius:999px;background:#d4fae8;color:#0fa76e;font-size:10px;font-weight:600;letter-spacing:0.4px;text-transform:uppercase;font-family:'Geist Mono','SFMono-Regular',Consolas,monospace;flex:0 0 auto;}.workspace-http-path{display:block;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-family:'Geist Mono','SFMono-Regular',Consolas,monospace;font-size:11px;line-height:16px;color:#0d0d0d;}.workspace-http-title-row{display:flex;align-items:center;gap:6px;min-width:0;margin-top:5px;}.workspace-http-title{display:block;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:16px;line-height:20px;font-weight:600;letter-spacing:-0.2px;color:#0d0d0d;font-family:Inter,'Helvetica Neue',Arial,sans-serif;}.workspace-http-subtitle{display:block;min-width:0;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;font-size:11px;line-height:16px;color:#6b7280;}.workspace-http-title-dot{flex:0 0 auto;color:#c7ccd4;font-size:10px;line-height:16px;}.workspace-http-meta{display:grid;grid-template-columns:repeat(3,minmax(70px,1fr));gap:6px;flex:0 0 216px;}.workspace-http-meta-card{border:1px solid rgba(16,24,40,0.08);border-radius:8px;padding:7px 8px;background:#fff;}.workspace-http-meta-label{font-family:'Geist Mono','SFMono-Regular',Consolas,monospace;font-size:9px;line-height:12px;letter-spacing:0.3px;text-transform:uppercase;color:#6b7280;}.workspace-http-meta-value{margin-top:3px;font-size:13px;line-height:16px;font-weight:600;color:#0d0d0d;}.workspace-http-section{margin-top:8px;border:1px solid rgba(16,24,40,0.08);border-radius:10px;background:#ffffff;box-shadow:0 1px 2px rgba(16,24,40,0.02);overflow:hidden;}.workspace-http-section-head{display:flex;align-items:center;justify-content:space-between;gap:8px;padding:8px 10px;border-bottom:1px solid rgba(16,24,40,0.06);background:linear-gradient(180deg,#fcfdfc 0%,#f6faf8 100%);}.workspace-http-section-title{font-size:12px;line-height:16px;font-weight:600;color:#0d0d0d;font-family:Inter,'Helvetica Neue',Arial,sans-serif;}.workspace-http-section-caption{font-family:'Geist Mono','SFMono-Regular',Consolas,monospace;font-size:9px;line-height:12px;letter-spacing:0.3px;text-transform:uppercase;color:#6b7280;}.workspace-http-info-grid{display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:8px;}.workspace-http-callout{padding:10px 12px;font-size:12px;line-height:18px;color:#374151;white-space:pre-wrap;background:linear-gradient(180deg,#ffffff 0%,#fbfcfc 100%);}.workspace-http-callout-muted{color:#475467;}.workspace-http-note-list{padding:6px 10px 8px 10px;display:block;}.workspace-http-note-item{font-size:11px;line-height:16px;color:#1f2937;padding:6px 0 6px 8px;border-bottom:1px dashed rgba(16,24,40,0.1);background:transparent;}.workspace-http-note-item:last-child{border-bottom:none;}.workspace-http-code-panel{height:260px;padding:0;overflow:hidden;background:#0b1020;}.workspace-http-code-shell{display:flex;align-items:center;justify-content:space-between;padding:7px 10px;border-bottom:1px solid rgba(255,255,255,0.08);background:#11182d;}.workspace-http-code-shell-title{font-size:11px;line-height:16px;font-weight:600;color:#f3f4f6;font-family:Inter,'Helvetica Neue',Arial,sans-serif;}.workspace-http-code-shell-badge{font-family:'Geist Mono','SFMono-Regular',Consolas,monospace;font-size:9px;line-height:14px;letter-spacing:0.3px;text-transform:uppercase;color:#a7f3d0;background:rgba(16,185,129,0.12);border:1px solid rgba(16,185,129,0.2);border-radius:999px;padding:0 6px;}.workspace-http-code-editor{height:calc(100% - 34px);}.workspace-http-table-wrap{padding:6px 8px 8px 8px;background:#ffffff;}.workspace-http-demo-wrap{padding:8px;background:#ffffff;}.workspace-http-demo-card{border:1px solid rgba(16,24,40,0.08);border-radius:8px;background:#ffffff;overflow:hidden;margin-bottom:6px;}.workspace-http-demo-trigger{display:flex;align-items:center;justify-content:space-between;padding:8px 10px;font-size:12px;line-height:16px;font-weight:600;color:#0d0d0d;cursor:pointer;background:linear-gradient(180deg,#fcfdfc 0%,#f7f9f8 100%);}.workspace-http-demo-state{font-family:'Geist Mono','SFMono-Regular',Consolas,monospace;font-size:9px;line-height:12px;letter-spacing:0.3px;text-transform:uppercase;color:#6b7280;}.workspace-http-demo-body{padding:8px 10px;border-top:1px solid rgba(16,24,40,0.06);font-size:12px;line-height:18px;white-space:pre-wrap;color:#374151;background:#ffffff;}.workspace-http-empty{padding:16px;color:#98a2b3;font-size:12px;line-height:18px;}@media (max-width:1200px){.workspace-http-hero-top{flex-wrap:wrap;}.workspace-http-meta{grid-template-columns:repeat(3,minmax(0,1fr));flex-basis:100%;}.workspace-http-info-grid{grid-template-columns:minmax(0,1fr);}}@media (max-width:768px){.workspace-http-doc{padding:6px;}.workspace-http-hero{padding:8px 10px;}.workspace-http-title-row,.workspace-http-headline{display:block;}.workspace-http-title-dot{display:none;}.workspace-http-title,.workspace-http-subtitle,.workspace-http-path{white-space:normal;overflow:visible;text-overflow:clip;}.workspace-http-meta{grid-template-columns:minmax(0,1fr);}}"
                                  },
