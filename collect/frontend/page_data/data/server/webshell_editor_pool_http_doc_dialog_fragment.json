{
  "tag": "dialog",
  "title": "${(()=>{const type=String(getFormValue('workspace-http-doc-form','type')||workspaceHttpDocFormType||'service');if(workspaceHttpDocOp==='add'){return type==='service'?'新增分组':'新增接口';}return type==='service'?'编辑分组':'编辑接口';})()}",
  "width": "90%",
  "wrapClassName": "workspace-http-doc-dialog-tight",
  "styles": {
    "body": {
      "padding": "10px 12px 8px",
      "maxHeight": "calc(100vh - 220px)",
      "overflow": "auto",
      "background": "linear-gradient(180deg,#f8fafc 0%,#f4f7fb 100%)"
    },
    "content": {
      "borderRadius": "12px",
      "overflow": "hidden"
    }
  },
  "zIndex": 1700,
  "open": "${workspaceHttpDocDialogVisible}",
  "cancelAction": [
    {
      "tag": "update-store",
      "value": {
        "workspaceHttpDocDialogVisible": false
      }
    }
  ],
  "action": [
    {
      "tag": "submit-form",
      "formName": "workspace-http-doc-form"
    },
    {
      "tag": "ajax",
      "enable": "${workspaceHttpDocOp==='add' && String(getFormValue('workspace-http-doc-form','type')||workspaceHttpDocFormType||'service')==='service'}",
      "showResultMsg": true,
      "api": "post:/template_data/data?service=config.doc_group_save",
      "data": {
        "doc_group_list": "${(()=>{const formName='workspace-http-doc-form';const selected=workspaceHttpDocForm||{};const projectCode=String(getFormValue(formName,'project_code')||selected.project_code||project_code||workspaceCurrent||'');return [{doc_group_id:String(getFormValue(formName,'doc_group_id')||selected.doc_group_id||''),name:(getFormValue(formName,'title')||'').trim(),desc:(getFormValue(formName,'sub_title')||'').trim(),type:String(getFormValue(formName,'type')||selected.type||workspaceHttpDocFormType||'service'),project_code:projectCode,order_index:Number(getFormValue(formName,'order_index')||1)}];})()}"
      }
    },
    {
      "tag": "ajax",
      "enable": "${workspaceHttpDocOp==='add' && String(getFormValue('workspace-http-doc-form','type')||workspaceHttpDocFormType||'service')!=='service'}",
      "showResultMsg": true,
      "api": "post:/template_data/data?service=config.doc_save",
      "data": {
        "doc": "${(()=>{const formName='workspace-http-doc-form';const selected=workspaceHttpDocForm||{};const parseJson=(text,fallback)=>{try{const raw=String(text===undefined||text===null?'':text).trim();return raw?JSON.parse(raw):fallback;}catch(err){return fallback;}};const requestValue=getFormValue(formName,'code');const headerValue=getFormValue(formName,'request_headers');const requestText=requestValue===undefined||requestValue===null||String(requestValue).trim()===''?String(selected.code||'{}'):String(requestValue);const headerText=headerValue===undefined||headerValue===null||String(headerValue).trim()===''?String(selected.request_headers||'{}'):String(headerValue);const headerObj=parseJson(headerText,parseJson(selected.request_headers,{}));const headersText=(()=>{try{return JSON.stringify(headerObj||{},null,2);}catch(err){return '{}';}})();const codeText=(()=>{const raw=String(requestText===undefined||requestText===null?'':requestText).trim();if(!raw){return '{}';}try{return JSON.stringify(JSON.parse(raw),null,2);}catch(err){return raw;}})();const projectCode=String(getFormValue(formName,'project_code')||selected.project_code||project_code||workspaceCurrent||'');return {title:(getFormValue(formName,'title')||'').trim(),sub_title:(getFormValue(formName,'sub_title')||'').trim(),type:String(getFormValue(formName,'type')||selected.type||workspaceHttpDocFormType||'2'),project_code:projectCode,parent_dir:String(getFormValue(formName,'parent_dir')||selected.parent_dir||''),order_index:Number(getFormValue(formName,'order_index')||1),request_mode:String(getFormValue(formName,'request_mode')||selected.request_mode||'frontend')==='backend'?'backend':'frontend',request_method:String(getFormValue(formName,'request_method')||selected.request_method||'post').toLowerCase(),request_url:String(getFormValue(formName,'request_url')||selected.request_url||'/template_data/data'),request_headers:headersText,code:codeText,code_desc:getFormValue(formName,'code_desc')||'',code_result:getFormValue(formName,'code_result')||''};})()}",
        "important_list": "${(()=>{const formName='workspace-http-doc-form';const list=Array.isArray(getFormValue(formName,'important_list'))?getFormValue(formName,'important_list'):[];return list.map((item,idx)=>Object.assign({},item,{name:item&&item.name?String(item.name):'',order_index:idx+1})).filter(item=>item.name);})()}",
        "params": "${(()=>{const formName='workspace-http-doc-form';const list=Array.isArray(getFormValue(formName,'params'))?getFormValue(formName,'params'):[];return list.map((item,idx)=>Object.assign({},item,{name:item&&item.name?String(item.name):'',type:item&&item.type?String(item.type):'',must:item&&item.must!==undefined&&item.must!==null?String(item.must):'',desc:item&&item.desc?String(item.desc):'',example:item&&item.example?String(item.example):'',order_index:idx+1})).filter(item=>item.name);})()}",
        "result": "${(()=>{const formName='workspace-http-doc-form';const list=Array.isArray(getFormValue(formName,'result'))?getFormValue(formName,'result'):[];return list.map((item,idx)=>Object.assign({},item,{name:item&&item.name?String(item.name):'',type:item&&item.type?String(item.type):'',must:item&&item.must!==undefined&&item.must!==null?String(item.must):'',desc:item&&item.desc?String(item.desc):'',example:item&&item.example?String(item.example):'',order_index:idx+1})).filter(item=>item.name);})()}",
        "demo": "${(()=>{const formName='workspace-http-doc-form';const list=Array.isArray(getFormValue(formName,'demo'))?getFormValue(formName,'demo'):[];return list.map((item,idx)=>Object.assign({},item,{name:item&&item.name?String(item.name):'',desc:item&&item.desc?String(item.desc):'',code:item&&item.code?String(item.code):'',code_result:item&&item.code_result?String(item.code_result):'',order_index:idx+1})).filter(item=>item.name||item.code||item.code_result);})()}"
      }
    },
    {
      "tag": "ajax",
      "enable": "${workspaceHttpDocOp==='edit'}",
      "showResultMsg": true,
      "api": "post:/template_data/data?service=config.doc_edit",
      "data": {
        "doc": "${(()=>{const formName='workspace-http-doc-form';const selected=workspaceHttpDocForm||{};const parseJson=(text,fallback)=>{try{const raw=String(text===undefined||text===null?'':text).trim();return raw?JSON.parse(raw):fallback;}catch(err){return fallback;}};const requestValue=getFormValue(formName,'code');const headerValue=getFormValue(formName,'request_headers');const requestText=requestValue===undefined||requestValue===null||String(requestValue).trim()===''?String(selected.code||'{}'):String(requestValue);const headerText=headerValue===undefined||headerValue===null||String(headerValue).trim()===''?String(selected.request_headers||'{}'):String(headerValue);const headerObj=parseJson(headerText,parseJson(selected.request_headers,{}));const headersText=(()=>{try{return JSON.stringify(headerObj||{},null,2);}catch(err){return '{}';}})();const codeText=(()=>{const raw=String(requestText===undefined||requestText===null?'':requestText).trim();if(!raw){return '{}';}try{return JSON.stringify(JSON.parse(raw),null,2);}catch(err){return raw;}})();const projectCode=String(getFormValue(formName,'project_code')||selected.project_code||project_code||workspaceCurrent||'');return {collect_doc_id:String(getFormValue(formName,'collect_doc_id')||selected.collect_doc_id||''),title:(getFormValue(formName,'title')||'').trim(),sub_title:(getFormValue(formName,'sub_title')||'').trim(),type:String(getFormValue(formName,'type')||selected.type||workspaceHttpDocFormType||'2'),project_code:projectCode,parent_dir:String(getFormValue(formName,'parent_dir')||selected.parent_dir||''),order_index:Number(getFormValue(formName,'order_index')||1),request_mode:String(getFormValue(formName,'request_mode')||selected.request_mode||'frontend')==='backend'?'backend':'frontend',request_method:String(getFormValue(formName,'request_method')||selected.request_method||'post').toLowerCase(),request_url:String(getFormValue(formName,'request_url')||selected.request_url||'/template_data/data'),request_headers:headersText,code:codeText,code_desc:getFormValue(formName,'code_desc')||'',code_result:getFormValue(formName,'code_result')||''};})()}",
        "important_list": "${(()=>{const formName='workspace-http-doc-form';const list=Array.isArray(getFormValue(formName,'important_list'))?getFormValue(formName,'important_list'):[];return list.map((item,idx)=>Object.assign({},item,{name:item&&item.name?String(item.name):'',order_index:idx+1})).filter(item=>item.name);})()}",
        "params": "${(()=>{const formName='workspace-http-doc-form';const list=Array.isArray(getFormValue(formName,'params'))?getFormValue(formName,'params'):[];return list.map((item,idx)=>Object.assign({},item,{name:item&&item.name?String(item.name):'',type:item&&item.type?String(item.type):'',must:item&&item.must!==undefined&&item.must!==null?String(item.must):'',desc:item&&item.desc?String(item.desc):'',example:item&&item.example?String(item.example):'',order_index:idx+1})).filter(item=>item.name);})()}",
        "result": "${(()=>{const formName='workspace-http-doc-form';const list=Array.isArray(getFormValue(formName,'result'))?getFormValue(formName,'result'):[];return list.map((item,idx)=>Object.assign({},item,{name:item&&item.name?String(item.name):'',type:item&&item.type?String(item.type):'',must:item&&item.must!==undefined&&item.must!==null?String(item.must):'',desc:item&&item.desc?String(item.desc):'',example:item&&item.example?String(item.example):'',order_index:idx+1})).filter(item=>item.name);})()}",
        "demo": "${(()=>{const formName='workspace-http-doc-form';const list=Array.isArray(getFormValue(formName,'demo'))?getFormValue(formName,'demo'):[];return list.map((item,idx)=>Object.assign({},item,{name:item&&item.name?String(item.name):'',desc:item&&item.desc?String(item.desc):'',code:item&&item.code?String(item.code):'',code_result:item&&item.code_result?String(item.code_result):'',order_index:idx+1})).filter(item=>item.name||item.code||item.code_result);})()}"
      }
    },
    {
      "tag": "update-store",
      "enable": "${workspaceHttpDocOp==='edit' && String(getFormValue('workspace-http-doc-form','type')||workspaceHttpDocFormType||'service')!=='service'}",
      "targetStore": "${activeStore}",
      "value": {
        "workspaceHttpDocRefreshVersion": "${uuid()}"
      }
    },
    {
      "tag": "update-store",
      "value": {
        "workspaceHttpDocDialogVisible": false
      }
    },
    {
      "tag": "reload-init-action",
      "targetStore": "${activeStore}",
      "group": "reload-workspace-http-tree"
    }
